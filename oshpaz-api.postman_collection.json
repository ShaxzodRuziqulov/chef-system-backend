{
  "info": {
    "name": "Oshpaz Backend API",
    "description": "Retsept va ovqat rejalashtirish tizimi — to'liq API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:8090", "type": "string" },
    { "key": "accessToken",  "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "userId",       "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 201) {",
              "  const j = pm.response.json();",
              "  const d = j.data || j;",
              "  pm.collectionVariables.set('accessToken',  d.accessToken  || d.access_token  || '');",
              "  pm.collectionVariables.set('refreshToken', d.refreshToken || d.refresh_token || '');",
              "  pm.test('Register 201', () => pm.response.to.have.status(201));",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"fullName\": \"Test Foydalanuvchi\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 200) {",
              "  const j = pm.response.json();",
              "  const d = j.data || j;",
              "  pm.collectionVariables.set('accessToken',  d.accessToken  || d.access_token  || '');",
              "  pm.collectionVariables.set('refreshToken', d.refreshToken || d.refresh_token || '');",
              "  pm.test('Login 200', () => pm.response.to.have.status(200));",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"1234\"\n}" }
          }
        },
        {
          "name": "Me (joriy user)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api","auth","me"] }
          }
        },
        {
          "name": "Profilni yangilash",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/auth/profile", "host": ["{{baseUrl}}"], "path": ["api","auth","profile"] },
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Yangi Ism\",\n  \"avatarUrl\": \"https://example.com/avatar.jpg\"\n}" }
          }
        },
        {
          "name": "Refresh Token",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 200) {",
              "  const j = pm.response.json();",
              "  const d = j.data || j;",
              "  pm.collectionVariables.set('accessToken',  d.accessToken  || d.access_token  || '');",
              "  pm.collectionVariables.set('refreshToken', d.refreshToken || d.refresh_token || '');",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api","auth","refresh"] },
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","auth","logout"] },
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}" }
          }
        }
      ]
    },

